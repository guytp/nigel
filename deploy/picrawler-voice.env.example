# Copy to /etc/picrawler-voice.env, chmod 600, fill in secrets.
OPENAI_API_KEY=sk-...
MCP_TOKEN=paste-same-token-as-picrawler-mcp.env

# Sound-device selection (indexes from `python -c "import sounddevice; print(sounddevice.query_devices())"`)
VOICE_INPUT_DEVICE=1
VOICE_OUTPUT_DEVICE=4

# Mic gain in dB — our USB mic is low-sensitivity, needs boost.
VOICE_MIC_GAIN_DB=24

# Noise gates (RMS, post-gain). Tune per room.
VOICE_NOISE_GATE_RMS=800
VOICE_BOT_SPEAKING_GATE_RMS=5000
VOICE_BOT_SPEAKING_WINDOW_S=0.5

# Server-side VAD (OpenAI).
VOICE_VAD_THRESHOLD=0.6
VOICE_VAD_SILENCE_MS=600

# Speaker volume ducking. Robot HAT speaker is card 3 on the Pi; 60-75%
# dramatically reduces mic bleed without killing intelligibility.
VOICE_SPEAKER_VOLUME_PCT=70
# VOICE_SPEAKER_CARD=3
# VOICE_SPEAKER_CONTROL=Digital

# Optional overrides:
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_VOICE=cedar        # cedar, marin, alloy, ash, ballad, coral, echo, sage, shimmer, verse
